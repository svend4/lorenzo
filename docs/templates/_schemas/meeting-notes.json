{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "meeting-notes",
  "description": "Протокол встречи: повестка, обсуждение, решения, action items",
  "type": "object",
  "required": ["template", "version", "title", "date"],
  "properties": {
    "template": {"const": "meeting-notes"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+$"},
    "title": {"type": "string", "minLength": 3},
    "date": {"type": "string", "format": "date"},
    "duration_minutes": {"type": "integer", "minimum": 1},
    "participants": {"type": "array", "items": {"type": "string"}},
    "location": {"type": "string"},
    "tags": {"type": "array", "items": {"type": "string"}}
  },
  "required_sections": ["Контекст", "Участники", "Повестка", "Обсуждение", "Принятые решения", "Action Items"]
}
