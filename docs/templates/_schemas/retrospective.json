{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "retrospective",
  "description": "Ретроспектива: что хорошо, что плохо, action items",
  "type": "object",
  "required": ["template", "version", "sprint", "period_from", "period_to"],
  "properties": {
    "template": {"const": "retrospective"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+$"},
    "sprint": {"type": "string"},
    "period_from": {"type": "string", "format": "date"},
    "period_to": {"type": "string", "format": "date"},
    "participants": {"type": "array", "items": {"type": "string"}},
    "tags": {"type": "array", "items": {"type": "string"}}
  },
  "required_sections": ["Период", "Action items для следующего периода"]
}
