{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "weekly-digest",
  "description": "Еженедельный дайджест: TL;DR, что сделано, метрики, решения, план",
  "type": "object",
  "required": ["template", "version", "period_from", "period_to"],
  "properties": {
    "template": {"const": "weekly-digest"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+$"},
    "period_from": {"type": "string", "format": "date"},
    "period_to": {"type": "string", "format": "date"},
    "week_number": {"type": "integer", "minimum": 1, "maximum": 53},
    "year": {"type": "integer", "minimum": 2024},
    "tags": {"type": "array", "items": {"type": "string"}}
  },
  "required_sections": ["TL;DR", "Что сделано", "Метрики недели", "План на следующую неделю"]
}
