{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "decision-record",
  "description": "Architecture Decision Record (ADR): контекст → варианты → решение → последствия",
  "type": "object",
  "required": ["template", "version", "adr_id", "title", "status", "date"],
  "properties": {
    "template": {"const": "decision-record"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+$"},
    "adr_id": {"type": "string", "pattern": "^ADR-\\d{4}$"},
    "title": {"type": "string", "minLength": 3},
    "status": {"enum": ["proposed", "accepted", "rejected", "deprecated", "superseded"]},
    "date": {"type": "string", "format": "date"},
    "deciders": {"type": "array", "items": {"type": "string"}},
    "tags": {"type": "array", "items": {"type": "string"}},
    "supersedes": {"type": ["string", "null"]},
    "superseded_by": {"type": ["string", "null"]}
  },
  "required_sections": ["Статус", "Контекст", "Рассмотренные варианты", "Принятое решение", "Последствия"]
}
