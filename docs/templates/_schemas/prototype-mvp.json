{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "prototype-mvp",
  "description": "План MVP с фазами, метриками успеха, рисками",
  "type": "object",
  "required": ["template", "version", "mvp_id", "title", "phase", "status"],
  "properties": {
    "template": {"const": "prototype-mvp"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+$"},
    "mvp_id": {"type": "string", "pattern": "^MVP-\\d{4}$"},
    "title": {"type": "string", "minLength": 3},
    "phase": {"type": "integer", "minimum": 0, "maximum": 5},
    "status": {"enum": ["planning", "in_progress", "blocked", "completed", "abandoned"]},
    "started": {"type": ["string", "null"], "format": "date"},
    "target_complete": {"type": ["string", "null"], "format": "date"},
    "success_metric": {"type": "string"},
    "tags": {"type": "array", "items": {"type": "string"}}
  },
  "required_sections": ["Цель", "Метрика успеха", "Состав", "Фазы", "Риски", "Что НЕ входит в MVP"]
}
