{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ensemble",
  "description": "Описание ансамбля компонентов: задача, состав, контракт, риски, MVP",
  "type": "object",
  "required": ["template", "version", "ensemble_name", "task"],
  "properties": {
    "template": {"const": "ensemble"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+$"},
    "ensemble_name": {"type": "string", "minLength": 1},
    "components": {"type": "array", "items": {"type": "string"}},
    "task": {"type": "string"},
    "maturity": {"enum": ["experimental", "alpha", "beta", "stable"]},
    "mvp_phase": {"type": "integer", "minimum": 0, "maximum": 5},
    "created": {"type": "string", "format": "date"},
    "tags": {"type": "array", "items": {"type": "string"}}
  },
  "required_sections": ["Назначение", "Компоненты", "Контракт взаимодействия", "Риски и ограничения", "MVP-шаги"]
}
